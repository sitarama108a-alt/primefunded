
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Details about the trader's profile.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "traderId": {
          "type": "string",
          "description": "Unique 8-digit numeric identifier for the trader."
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "tier": {
          "type": "string",
          "enum": [
            "Bronze",
            "Silver",
            "Gold"
          ]
        },
        "joinDate": {
          "type": "string",
          "format": "date-time"
        },
        "balance": {
          "type": "number"
        },
        "equity": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "suspended"
          ]
        },
        "kycVerified": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "email"
      ]
    },
    "Order": {
      "title": "Order",
      "description": "A challenge purchase order.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "plan": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "price": {
          "type": "string"
        },
        "network": {
          "type": "string"
        },
        "txHash": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "verified",
            "rejected"
          ]
        },
        "date": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "TradingAccount": {
      "title": "Trading Account",
      "description": "Details of an MT5 trading account.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "plan": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "mt5Login": {
          "type": "string"
        },
        "mt5Password": {
          "type": "string"
        },
        "mt5Server": {
          "type": "string"
        },
        "balance": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "breached",
            "passed"
          ]
        },
        "startDate": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "PayoutRequest": {
      "title": "Payout Request",
      "description": "A request for a profit withdrawal.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "amount": {
          "type": "string"
        },
        "method": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "done",
            "rejected"
          ]
        },
        "date": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/UserProfile"
      },
      "description": "Stores trader profiles."
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/backend/entities/Order"
      },
      "description": "Stores challenge purchase orders."
    },
    "/accounts/{accountId}": {
      "schema": {
        "$ref": "#/backend/entities/TradingAccount"
      },
      "description": "Stores provisioned MT5 accounts."
    },
    "/payouts/{payoutId}": {
      "schema": {
        "$ref": "#/backend/entities/PayoutRequest"
      },
      "description": "Stores profit withdrawal requests."
    }
  }
}
