
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Details about the trader's profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "traderId": { "type": "string" },
        "referralCode": { "type": "string" },
        "codeChangesCount": { "type": "number" },
        "lastCodeChange": { "type": "string", "format": "date-time" },
        "referredBy": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "country": { "type": "string" },
        "tier": { "type": "string", "enum": ["Bronze", "Silver", "Gold"] },
        "joinDate": { "type": "string", "format": "date-time" },
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "kycVerified": { "type": "boolean" },
        "kycStatus": { "type": "string", "enum": ["none", "pending", "verified", "rejected"] },
        "kycRejectionReason": { "type": "string" },
        "kycSubmittedAt": { "type": "string", "format": "date-time" },
        "idProofUrl": { "type": "string" },
        "addressProofUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "Mt5Account": {
      "title": "MT5 Account Sync",
      "description": "Real-time metrics and compliance status for a trading account.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "login": { "type": "string" },
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "profit": { "type": "number" },
        "startingBalance": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "terminated", "warning", "passed"] },
        "planType": { "type": "string", "enum": ["1-step-pro", "2-step-classic", "3-step-classic", "instant-funding"] },
        "phase": { "type": "string", "enum": ["evaluation", "phase1", "phase2", "phase3", "funded"] },
        "breachType": { "type": "string", "enum": ["hard", "soft"] },
        "breachReason": { "type": "string" },
        "breachTime": { "type": "string", "format": "date-time" },
        "profitPct": { "type": "number" },
        "dailyDrawdownPct": { "type": "number" },
        "maxDrawdownPct": { "type": "number" },
        "floatingLossPct": { "type": "number" },
        "tradingDays": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "DemoAccount": {
      "title": "Demo Account",
      "description": "Virtual trading account for practice.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "plan": { "type": "string", "enum": ["10k", "25k", "50k"] },
        "label": { "type": "string" },
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "startBalance": { "type": "number" },
        "maxLoss": { "type": "number" },
        "dailyLoss": { "type": "number" },
        "profitTarget": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "blown", "passed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DemoTrade": {
      "title": "Demo Trade",
      "description": "A single trade execution in the demo environment.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "accountId": { "type": "string" },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "lots": { "type": "number" },
        "openPrice": { "type": "number" },
        "sl": { "type": ["number", "null"] },
        "tp": { "type": ["number", "null"] },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "closeReason": { "type": "string", "enum": ["manual", "stop_loss", "take_profit", "liquidation", "daily_reset"] },
        "pnl": { "type": "number" },
        "openedAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": ["string", "null"], "format": "date-time" },
        "closePrice": { "type": ["number", "null"] }
      }
    },
    "LivePrice": {
      "title": "Live Price",
      "description": "Real-time asset pricing for the demo environment.",
      "type": "object",
      "properties": {
        "pair": { "type": "string" },
        "price": { "type": "number" },
        "bid": { "type": "number" },
        "ask": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Alert": {
      "title": "Price Alert",
      "description": "User-defined price alerts for symbols.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "condition": { "type": "string", "enum": ["above", "below"] },
        "targetPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "triggered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores trader profiles."
    },
    "/mt5_accounts/{accountId}": {
      "schema": { "$ref": "#/backend/entities/Mt5Account" },
      "description": "Real-time terminal metrics and compliance tracking."
    },
    "/demoAccounts/{accountId}": {
      "schema": { "$ref": "#/backend/entities/DemoAccount" },
      "description": "User demo accounts."
    },
    "/demoTrades/{tradeId}": {
      "schema": { "$ref": "#/backend/entities/DemoTrade" },
      "description": "Trades within demo accounts."
    },
    "/livePrices/{symbol}": {
      "schema": { "$ref": "#/backend/entities/LivePrice" },
      "description": "Real-time price feeds for demo environment."
    },
    "/alerts/{alertId}": {
      "schema": { "$ref": "#/backend/entities/Alert" },
      "description": "Stores user price alerts."
    }
  }
}
