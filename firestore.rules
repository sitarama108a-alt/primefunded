rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public read for branding/settings
    match /settings/{document} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK
    }

    match /users/{userId} {
      // User can only read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /accounts/{accId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Managed by terminal/admin
      }
    }
    
    match /mt5_accounts/{accountId} {
       // Users should be able to read their own sync data
       allow read: if request.auth != null && resource.data.userId == request.auth.uid;
       allow write: if false; // Managed by EA/API
    }

    match /orders/{orderId} {
      // User can create orders and read their own
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /payouts/{payoutId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /referrals/{refId} {
      allow read: if request.auth != null && (resource.data.referrerId == request.auth.uid || resource.data.referredUserId == request.auth.uid);
    }
    
    match /referralCodes/{code} {
      allow read: if true; // Public for signup validation
      allow write: if request.auth != null;
    }
    
    match /breaches/{breachId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    match /broadcasts/{doc} {
      allow read: if request.auth != null;
    }

    // Allow admin terminal to function with full access (fallback for testing)
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}