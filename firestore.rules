rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Input validation function: ensures incoming data is not empty
    function validateInput(data) {
      return data != null && data.size() > 0;
    }

    // --- Collection Rules ---

    // Users: Users can only read/write their own profile and sub-collections
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && validateInput(request.resource.data);
      
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Accounts: Users can read their own MT5 credentials; only admins can provision/update
    match /accounts/{accountId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    // Orders: Users can read their own orders and create new ones; only admins can verify/update
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && validateInput(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Payouts: Users can read/write their own withdrawal requests
    match /payouts/{payoutId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid) && (request.resource == null || request.resource.data.userId == request.auth.uid);
    }

    // Admin: Entirely restricted to administrative users
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // Broadcasts: Global read for authenticated users; write restricted to admins
    match /broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Referrals: Referrers can see their earnings; registry is writable for code setup
    match /referrals/{referralId} {
      allow read: if isSignedIn() && (resource == null || resource.data.referrerId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /referralCodes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && validateInput(request.resource.data);
    }

    // --- Global Deny ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}