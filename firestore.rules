rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /livePrices/{symbol} {
      allow read: if true;
      allow write: if false;
    }

    match /candles/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /demoAccounts/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /demoTrades/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /mt5_accounts/{id} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.uid != null
      );
      allow write: if false;
    }

    match /mt5_trades/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /orders/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /payouts/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /breaches/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;

      match /{subcollection=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /notifications/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Support for referral system
    match /referrals/{id} {
      allow read: if request.auth != null && (resource.data.referrerId == request.auth.uid || resource.data.referredUserId == request.auth.uid);
      allow write: if false;
    }
    match /referralCodes/{code} {
      allow read: if true;
      allow write: if false;
    }
  }
}