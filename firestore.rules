rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profile & Subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null;
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Orders Ledger
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    // Payouts Ledger
    match /payouts/{payoutId} {
      allow read, write: if request.auth != null;
    }

    // Breach Ledger
    match /breaches/{breachId} {
      allow read, write: if request.auth != null;
    }

    // Referral Tracking
    match /referrals/{refId} {
      allow read, write: if request.auth != null;
    }
    
    match /referralCodes/{code} {
      allow read: if true; 
      allow write: if request.auth != null;
    }

    // Platform Settings (Branding, etc)
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // MT5 Account Sync Data
    match /mt5_accounts/{accountId} {
       allow read, write: if request.auth != null;
    }

    // Global Fallback
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}