rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public read for branding/settings
    // This allows the logo and site name to load on the landing page
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow public read for leaderboard and rankings
    match /leaderboard/{document} {
      allow read: if true;
    }

    match /ranking/{document} {
      allow read: if true;
    }
    
    // Allow authenticated users to read and write everything else
    // In production, you should refine this to enforce ownership (e.g. users/{userId})
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Specific user profile rules (already covered by catch-all but kept for clarity)
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Allow users to submit their own orders
    match /orders/{orderId} {
      allow write: if request.auth != null;
    }
  }
}