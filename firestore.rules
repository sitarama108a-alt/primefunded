
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // BROAD READ PERMISSIONS FOR PREVIEW
    // In production, these should be restricted to isAdmin()
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }

      match /accounts/{accountId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /mt5_accounts/{accountId} {
      allow write: if true; 
      allow read: if true;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /payouts/{payoutId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.resource.data.userId == request.auth.uid);
    }

    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /referralCodes/{codeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /referrals/{refId} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    match /error_logs/{logId} {
      allow create: if true; 
      allow read: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
