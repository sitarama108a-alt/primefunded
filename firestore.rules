rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Publicly readable market data
    match /livePrices/{symbol} {
      allow read: if true;
      allow write: if false;
    }

    match /candles/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // User-specific Demo Data
    match /demoAccounts/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /demoTrades/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // User-specific Institutional Data
    match /mt5_accounts/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /mt5_trades/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    
    // Main User Profiles and sub-collections
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
      
      match /notifications/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /trades/{id} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }

    // General app collections with auth checks
    match /payouts/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /orders/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /breaches/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    match /referrals/{id} {
      allow read: if request.auth != null && (resource.data.referrerId == request.auth.uid || resource.data.referredUserId == request.auth.uid);
      allow write: if false;
    }
    match /referralCodes/{code} {
      allow read: if true;
      allow write: if false;
    }
  }
}