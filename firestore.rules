rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for site-wide settings and branding
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow public read for leaderboard and rankings
    match /leaderboard/{document} {
      allow read: if true;
    }

    match /ranking/{document} {
      allow read: if true;
    }
    
    // Allow authenticated users to read everything else
    match /{document=**} {
      allow read: if request.auth != null;
    }
    
    // Allow authenticated users to write their own profile data
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Allow access to subcollections like notifications and accounts
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Allow users to submit their own orders for verification
    match /orders/{orderId} {
      allow write: if request.auth != null;
    }

    // Allow MT5 sync accounts to be readable/writable for performance updates
    match /mt5_accounts/{accountId} {
      allow read, write: if request.auth != null;
    }
  }
}