rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if the user is a verified administrator
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Identify if the document belongs to the requesting user
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // User Profile: Owners can read/update limited fields. Admin has full access.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if request.auth != null; // Allow initial signup
      allow update: if isAdmin() || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['accountStatus', 'accountPlan', 'accountSize', 'accountBalance', 'liveBalance', 'liveEquity', 'readyForNextPhase', 'role', 'traderId', 'uid'])
      );

      match /notifications/{id} {
        allow read: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /trades/{id} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin(); // Only server/admin can write trades
      }
      
      match /performance/{id} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }
    
    // MT5 Accounts: Only server/admin can write. Owners can only read.
    match /mt5_accounts/{accountId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    
    // Orders: Users can create and read their own. Admin manages.
    match /orders/{orderId} {
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    
    // Payouts: Users can create and read their own. Admin manages.
    match /payouts/{payoutId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Breach Ledger: Read-only for owners. Write-only for Admin.
    match /breaches/{breachId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Referral Tracking: Public read for codes, Admin write.
    match /referralCodes/{code} {
      allow read: if true; 
      allow write: if isAdmin() || (request.auth != null && !resource.data.diff(request.resource.data).affectedKeys().hasAny(['userId']));
    }
    
    match /referrals/{refId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.referrerId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Platform Settings: Public read, Admin write.
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Broadcasts: Public read, Admin write.
    match /broadcasts/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}